# Ignore everything by default
/*
!/.config/
/.config/*
!/.config/dotfiles/
/.config/dotfiles/*

# Always ignore patterns
# regardless of exceptions
.nvim
*.out

# Whitelist
!/.gitignore
!/README.md
!/.profile

